<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net8.0</TargetFramework>
        <Nullable>enable</Nullable>
        <AnalysisMode>AllEnabledByDefault</AnalysisMode>
        <PackageTags>outbox business-transaction consistency EF implementation</PackageTags>
        <InformationalVersion>8.5</InformationalVersion>
        <PackageVersion>8.5.0</PackageVersion>
        <AssemblyVersion>$(PackageVersion)</AssemblyVersion>
        <FileVersion>$(PackageVersion)</FileVersion>
    </PropertyGroup>

    <!--Для NuGet-->
    <PropertyGroup>
        <PackageProjectUrl>https://github.com/dex-it/dex-common/tree/main/src/Dex.Cap</PackageProjectUrl>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <Authors>dex team</Authors>
        <PackageReleaseNotes>8.5.0: размер Content ограничен опцией MaxContentLength (дефолт 1 МиБ, байты UTF-8), постановка тела сверх предела бросает OutboxContentTooLargeException. AddOutbox теперь взводит ValidateOnStart на OutboxOptions: неположительный MaxContentLength роняет старт хоста, и там же исполняются все зарегистрированные вами IValidateOptions&lt;OutboxOptions&gt;. Миграция не нужна. Поднять предел: services.Configure&lt;OutboxOptions&gt;(o =&gt; o.MaxContentLength = 8 * 1024 * 1024). Полный список изменений поведения: https://github.com/dex-it/dex-common/tree/main/src/Dex.Cap#breaking-changes</PackageReleaseNotes>
        <ContinuousIntegrationBuild>true</ContinuousIntegrationBuild>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
        <PublishRepositoryUrl>true</PublishRepositoryUrl>
        <EmbedUntrackedSources>true</EmbedUntrackedSources>
        <IncludeSymbols>true</IncludeSymbols>
        <SymbolPackageFormat>snupkg</SymbolPackageFormat>
        <GeneratePackageOnBuild Condition="'$(Configuration)'=='Release'">true</GeneratePackageOnBuild>
    </PropertyGroup>
    <ItemGroup>
        <PackageReference Include="Microsoft.SourceLink.GitHub" PrivateAssets="All"/>
    </ItemGroup>
    <!--/Для NuGet-->

    <ItemGroup>
        <ProjectReference Include="..\Dex.Cap.Common.Ef\Dex.Cap.Common.Ef.csproj"/>
        <ProjectReference Include="..\Dex.Cap.Outbox.AspNetScheduler\Dex.Cap.Outbox.AspNetScheduler.csproj" />
        <ProjectReference Include="..\Dex.Cap.Outbox\Dex.Cap.Outbox.csproj"/>
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.EntityFrameworkCore"/>
        <PackageReference Include="Microsoft.EntityFrameworkCore.Relational"/>
        <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions"/>
    </ItemGroup>

</Project>

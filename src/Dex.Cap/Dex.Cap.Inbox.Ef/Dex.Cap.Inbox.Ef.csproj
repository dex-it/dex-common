<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net8.0</TargetFramework>
        <Nullable>enable</Nullable>
        <AnalysisMode>AllEnabledByDefault</AnalysisMode>
        <PackageTags>inbox business-transaction consistency idempotency EF implementation</PackageTags>
        <InformationalVersion>8.5</InformationalVersion>
        <PackageVersion>8.5.0</PackageVersion>
        <AssemblyVersion>$(PackageVersion)</AssemblyVersion>
        <FileVersion>$(PackageVersion)</FileVersion>
    </PropertyGroup>

    <!--Для NuGet-->
    <PropertyGroup>
        <PackageProjectUrl>https://github.com/dex-it/dex-common/tree/main/src/Dex.Cap</PackageProjectUrl>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <Authors>dex team</Authors>
        <Description>Хранилище Dex.Cap.Inbox на Entity Framework Core и PostgreSQL: атомарный захват сообщения и его обработка в одной транзакции с обработчиком.</Description>
        <PackageReleaseNotes>8.5.0: размер Content ограничен опцией MaxContentLength (дефолт 1 МиБ, байты UTF-8), приём тела сверх предела бросает InboxContentTooLargeException. Проверка идёт до записи в БД, неположительное значение роняет старт хоста (AddInbox валидирует опции на старте). Миграция не нужна. Поднять предел: services.Configure&lt;InboxOptions&gt;(o =&gt; o.MaxContentLength = 8 * 1024 * 1024). Полный список изменений поведения: https://github.com/dex-it/dex-common/tree/main/src/Dex.Cap#breaking-changes</PackageReleaseNotes>
        <ContinuousIntegrationBuild>true</ContinuousIntegrationBuild>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
        <PublishRepositoryUrl>true</PublishRepositoryUrl>
        <EmbedUntrackedSources>true</EmbedUntrackedSources>
        <IncludeSymbols>true</IncludeSymbols>
        <SymbolPackageFormat>snupkg</SymbolPackageFormat>
        <GeneratePackageOnBuild Condition="'$(Configuration)'=='Release'">true</GeneratePackageOnBuild>
    </PropertyGroup>
    <ItemGroup>
        <PackageReference Include="Microsoft.SourceLink.GitHub" PrivateAssets="All"/>
    </ItemGroup>
    <!--/Для NuGet-->

    <ItemGroup>
        <ProjectReference Include="..\Dex.Cap.Common.Ef\Dex.Cap.Common.Ef.csproj"/>
        <ProjectReference Include="..\Dex.Cap.Inbox.AspNetScheduler\Dex.Cap.Inbox.AspNetScheduler.csproj"/>
        <ProjectReference Include="..\Dex.Cap.Inbox\Dex.Cap.Inbox.csproj"/>
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.EntityFrameworkCore"/>
        <PackageReference Include="Microsoft.EntityFrameworkCore.Relational"/>
        <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions"/>
    </ItemGroup>
</Project>

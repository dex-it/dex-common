<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net8.0</TargetFramework>
        <AnalysisMode>AllEnabledByDefault</AnalysisMode>
        <Nullable>enable</Nullable>
        <PackageTags>inbox business-transaction consistency idempotency</PackageTags>
        <InformationalVersion>8.5</InformationalVersion>
        <PackageVersion>8.5.0</PackageVersion>
        <AssemblyVersion>$(PackageVersion)</AssemblyVersion>
        <FileVersion>$(PackageVersion)</FileVersion>
    </PropertyGroup>

    <!--Для NuGet-->
    <PropertyGroup>
        <PackageProjectUrl>https://github.com/dex-it/dex-common/tree/main/src/Dex.Cap</PackageProjectUrl>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <Authors>dex team</Authors>
        <Description>Transactional Inbox: дедупликация входящих сообщений и store-and-forward. Повторная доставка не применяет эффект второй раз (effectively once). Транспорт- и storage-агностичное ядро.</Description>
        <PackageReleaseNotes>8.5.0: размер Content ограничен опцией MaxContentLength (дефолт 1 МиБ, байты UTF-8). Приём тела сверх предела бросает InboxContentTooLargeException; проверка идёт до записи в БД, миграция не нужна. Поднять предел: services.Configure&lt;InboxOptions&gt;(o =&gt; o.MaxContentLength = 8 * 1024 * 1024). Полный список изменений поведения: https://github.com/dex-it/dex-common/tree/main/src/Dex.Cap#breaking-changes</PackageReleaseNotes>
        <ContinuousIntegrationBuild>true</ContinuousIntegrationBuild>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
        <PublishRepositoryUrl>true</PublishRepositoryUrl>
        <EmbedUntrackedSources>true</EmbedUntrackedSources>
        <IncludeSymbols>true</IncludeSymbols>
        <SymbolPackageFormat>snupkg</SymbolPackageFormat>
        <GeneratePackageOnBuild Condition="'$(Configuration)'=='Release'">true</GeneratePackageOnBuild>
    </PropertyGroup>
    <ItemGroup>
        <PackageReference Include="JetBrains.Annotations"/>
        <PackageReference Include="Microsoft.SourceLink.GitHub" PrivateAssets="All"/>
    </ItemGroup>
    <!--/Для NuGet-->

    <ItemGroup>
        <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions"/>
        <PackageReference Include="Microsoft.Extensions.Logging.Abstractions"/>
        <PackageReference Include="Microsoft.Extensions.Options"/>
        <PackageReference Include="System.Diagnostics.DiagnosticSource"/>
    </ItemGroup>

</Project>
